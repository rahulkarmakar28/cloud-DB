# Copy this to .env and fill in your values

# ── PostgreSQL (internal store) ───────────────────────────
DB_HOST=postgres #localhost for local env
DB_PORT=5432
DB_NAME=dbcloud
DB_USER=dbcloud
DB_PASSWORD=dbcloud_secret

# ── JWT Secrets (use long random strings!) ────────────────
JWT_SECRET=replace_with_64_char_random_string_openssl_rand_hex_32
JWT_EXPIRES=15m
REFRESH_SECRET=replace_with_another_64_char_random_string
REFRESH_EXPIRES=7d

# ── Kubernetes ────────────────────────────────────────────
KUBECONFIG=/root/.kube/config
# StorageClass to use for PVCs (leave empty for cluster default)
# STORAGE_CLASS=gp3

# ── Server ────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
